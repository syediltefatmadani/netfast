PORT=7000
NODE_ENV=development
# Local: mongodb://127.0.0.1:27017/focuslock  |  Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/focuslock
MONGO_URI=mongodb://127.0.0.1:27017/focuslock
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=30d
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RESEND_API_KEY=re_xxxx
FROM_EMAIL=noreply@focuslock.app
REDIS_URL=redis://localhost:6379
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:7000

# Semicolon-separated .env files to read MONGO_URL for Atlas DNS diagnostics
# NETFAST_MONGO_ENV_PATHS=D:\shelfmerch\shelfmerch-printify-clone\backend\.env
# Emergency Atlas hosts-file fallback (default off — mongodb+srv uses Windows DNS)
# MONGO_HOSTS_FALLBACK=false
# Supplemental hosts blocklist for sites that bypass CleanBrowsing plain DNS (default on)
# NETFAST_HOSTS_BLOCK=1
# Policy mode: strict (default) | developer | testing | repair
# Developer mode keeps CleanBrowsing/DoH active but allows trusted dev tools (requires admin)
# NETFAST_POLICY_MODE=strict
