{
  "name": "focuslock",
  "version": "1.0.0",
  "main": "electron/main.js",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:react\" \"npm run dev:electron:safe\"",
    "dev:react": "vite dev",
    "dev:electron": "npm run dev:electron:safe",
    "dev:electron:safe": "wait-on http://localhost:5173 && cross-env NODE_ENV=development NETFAST_DISABLE_ENFORCEMENT=true electron .",
    "dev:electron:enforce": "wait-on http://localhost:5173 && cross-env NODE_ENV=development NETFAST_DISABLE_ENFORCEMENT=false NETFAST_ALLOW_REAL_ENFORCEMENT=true electron .",
    "dev:enforce": "concurrently \"npm run dev:server\" \"npm run dev:react\" \"npm run dev:electron:enforce\"",
    "reset:network": "powershell -ExecutionPolicy Bypass -File scripts/reset-netfast-network.ps1",
    "dev:server": "nodemon server/index.js",
    "build": "vite build && electron-builder",
    "build:dev": "vite build --mode development",
    "server": "node server/index.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:dns": "node --test electron/services/dns/tests/*.test.js",
    "health-doh": "node electron/cli.js health-doh",
    "diagnose-domain": "node electron/cli.js diagnose-domain",
    "service:run": "node service/index.js",
    "service:build": "node -e \"console.log('NetFastService is plain JS — no build step required.')\"",
    "service:install": "node service/install.js",
    "service:uninstall": "node service/uninstall.js",
    "service:start": "node service/control.js start",
    "service:stop": "node service/control.js stop",
    "service:status": "node service/control.js status",
    "service:logs": "node service/logs.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/router-plugin": "^1.167.28",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.1.7",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.575.0",
    "mongoose": "^8.0.3",
    "node-cron": "^3.0.3",
    "node-windows": "^1.0.0-beta.8",
    "razorpay": "^2.9.2",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "resend": "^2.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "wait-on": "^7.2.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "app.focuslock.desktop",
    "productName": "FocusLock",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*", "service/**/*", "shared/**/*", "node_modules/**/*"],
    "win": { "target": "nsis", "requestedExecutionLevel": "requireAdministrator" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "runAfterFinish": true }
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "^2.1.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "nitro": "3.0.260429-beta",
    "nodemon": "^3.0.2",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
